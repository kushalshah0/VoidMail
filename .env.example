# VoidMail Environment Variables
# Copy this to .env and fill in your values

# Email domain (for receiving emails)
VITE_EMAIL_DOMAIN=yourdomain.com

# KV Namespace IDs (from Cloudflare Dashboard)
# Get these from: Cloudflare Dashboard → KV → Your Namespace → API ID
VOIDMAIL_KV_ID=
VOIDMAIL_KV_PREVIEW_ID=
