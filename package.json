{
  "name": "voidmail-cloudflare",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev --compatibility-date=2024-01-01 dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "kv:create": "wrangler kv namespace create VOIDMAIL_KV",
    "kv:create:preview": "wrangler kv namespace create VOIDMAIL_KV --preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wrangler": "^3.60.0"
  }
}
